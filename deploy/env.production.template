# Personal Assistant CN — 生产环境模板（无真实密钥，可提交）
# 一键合并：在项目根目录执行  python scripts/merge_env_to_production.py
# （从本地 .env 拷密钥 → 写入 .gitignore 的 .env.production）

# LLM 配置
LLM_PROVIDER=openai
LLM_API_KEY=<your-api-key>
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_FAST_MODEL=gpt-4o-mini

# 数据库（Docker Compose 内部网络）
DATABASE_URL=postgresql+asyncpg://assistant:assistant@database:5432/assistant_cn

# Redis
REDIS_URL=redis://redis:6379/0

# 搜索
SEARXNG_URL=http://searxng:8080

# 应用
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_SECRET_KEY=<generate-a-random-string>
MEMORY_MODE=persistent

# 金融数据
TUSHARE_TOKEN=<your-tushare-token>
# EM_PROXY_URL=

# 企业微信（可选）
# WECOM_CORP_ID=
# WECOM_AGENT_ID=
# WECOM_SECRET=
# WECOM_TOKEN=
# WECOM_ENCODING_AES_KEY=

# 飞书（可选）
FEISHU_APP_ID=<your-feishu-app-id>
FEISHU_APP_SECRET=<your-feishu-app-secret>
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
