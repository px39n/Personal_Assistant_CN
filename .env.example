# LLM 配置
LLM_PROVIDER=openai           # openai / deepseek / qwen / moonshot
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_FAST_MODEL=gpt-4o-mini    # 用于工具选择等轻量任务

# 数据库
DATABASE_URL=postgresql+asyncpg://assistant:assistant@localhost:5432/assistant_cn

# Redis
REDIS_URL=redis://localhost:6379/0

# 搜索
SEARXNG_URL=http://localhost:8888

# Tushare (可选，A 股数据)
TUSHARE_TOKEN=

# 应用
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# 飞书 (可选)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
